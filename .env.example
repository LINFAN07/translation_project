# Copy to .env and fill in (never commit .env)

# Direct Gemini (local dev when GEMINI_WORKER_URL is not set)
GEMINI_API_KEY=

# Cloudflare Worker proxy — Google key stored only in Worker Secrets
# GEMINI_WORKER_URL=https://translation-gemini-proxy.your-account.workers.dev
# GEMINI_WORKER_AUTH=long-random-secret-matching-WORKER_AUTH_SECRET
